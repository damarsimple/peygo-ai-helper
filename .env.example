# Local vLLM endpoint (Qwen3-27B-A3B on RTX 5090)
OPENAI_API_KEY=EMPTY
OPENAI_BASE_URL=http://host.docker.internal:8000/v1

# Override model name if needed (default: Qwen3-27B-A3B)
MODEL_NAME=Qwen3-27B-A3B

# Or for OpenAI API:
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-3.5-turbo

# Or for Ollama:
# OPENAI_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=ollama/llama3

# Tavily API key for web search (free tier: https://tavily.com)
# Falls back to DuckDuckGo + LLM if not set
TAVILY_API_KEY=your_tavily_api_key_here