OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
# Or for Ollama: OPENAI_BASE_URL=http://localhost:11434/v1
# For other OpenAI-compatible endpoints, set the appropriate URL

# Optional: Override model name (default: openai/Qwen3.6-27B)
# Format: provider/model_name (e.g., openai/gpt-4, ollama/llama3)
# When using OPENAI_BASE_URL with custom endpoint, use openai/ prefix
# MODEL_NAME=openai/gpt-4
# For Ollama: MODEL_NAME=ollama/llama3

# Tavily API key for web search (free tier: https://tavily.com)
# Falls back to DuckDuckGo + LLM if not set
TAVILY_API_KEY=your_tavily_api_key_here